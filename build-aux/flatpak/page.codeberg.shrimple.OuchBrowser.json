{
	"$schema": "https://github.com/flatpak/flatpak-builder/raw/refs/heads/main/data/flatpak-manifest.schema.json",
	"id": "page.codeberg.shrimple.OuchBrowser",
	"runtime": "org.gnome.Platform",
	"runtime-version": "50",
	"sdk": "org.gnome.Sdk",
	"sdk-extensions": ["org.freedesktop.Sdk.Extension.dotnet10"],
	"command": "OuchBrowser",
	"finish-args": [
		"--share=network",
		"--share=ipc",
		"--socket=fallback-x11",
		"--socket=cups",
		"--socket=pulseaudio",
		"--socket=wayland",
		"--filesystem=home"
	],
	"build-options": {
		"append-path": "/usr/lib/sdk/dotnet10/bin",
		"append-ld-library-path": "/usr/lib/sdk/dotnet10/lib",
		"prepend-pkg-config-path": "/usr/lib/sdk/dotnet10/lib/pkgconfig",
		"env": {
			"DOTNET_NOLOGO": "true",
			"DOTNET_CLI_TELEMETRY_OPTOUT": "true"
		}
	},
	"cleanup": [
		"/include",
		"/lib/pkgconfig",
		"/man",
		"/share/doc",
		"/share/gtk-doc",
		"/share/man",
		"/share/pkgconfig",
		"*.la",
		"*.a"
	],
	"modules": [
		{
			"name": "OuchBrowser",
			"builddir": true,
			"buildsystem": "simple",
			"build-options": {
				"arch": {
					"aarch64": {
						"env": {
							"RUNTIME": "linux-arm64"
						}
					},
					"x86_64": {
						"env": {
							"RUNTIME": "linux-x64"
						}
					}
				}
			},
			"modules": [
				{
					"name": "just",
					"buildsystem": "simple",
					"build-commands": ["install -Dm755 just --target-directory /app/bin"],
					"sources": [
						{
							"type": "archive",
							"strip-components": 0,
							"dest-filename": "just.tar.gz",
							"url": "https://github.com/casey/just/releases/download/1.50.0/just-1.50.0-x86_64-unknown-linux-musl.tar.gz",
							"sha256": "27e011cd6328fadd632e59233d2cf5f18460b8a8c4269acd324c1a8669f34db0",
							"only-arches": ["x86_64"]
						},
						{
							"type": "archive",
							"strip-components": 0,
							"dest-filename": "just.tar.gz",
							"url": "https://github.com/casey/just/releases/download/1.50.0/just-1.50.0-aarch64-unknown-linux-musl.tar.gz",
							"sha256": "3beb4967ce05883cf09ac12d6d128166eb4c6d0b03eff74b61018a6880655d7d",
							"only-arches": ["aarch64"]
						}
					]
				}
			],
			"build-commands": [
				"just build-blueprint",
				"just compile-resources",
				"just PREFIX=${FLATPAK_DEST} build-translations",
				"just PREFIX=${FLATPAK_DEST} build-schemas",
				"dotnet publish OuchBrowser -c Release -o ${FLATPAK_DEST}/bin --source ./nuget-sources",

				"install -Dm644 OuchBrowser/Data/Icons/Hicolor/Symbolic/Apps/${FLATPAK_ID}-symbolic.svg --target-directory ${FLATPAK_DEST}/share/icons/hicolor/symbolic/apps",
				"install -Dm644 OuchBrowser/Data/Icons/Hicolor/Scalable/Apps/${FLATPAK_ID}.svg --target-directory ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps",
				"install -Dm644 OuchBrowser/Data/${FLATPAK_ID}.desktop --target-directory ${FLATPAK_DEST}/share/applications",
				"install -Dm644 OuchBrowser/Data/${FLATPAK_ID}.metainfo.xml --target-directory ${FLATPAK_DEST}/share/metainfo"
			],
			"sources": [
				"nuget-sources.json",
				{
					"type": "dir",
					"path": "../.."
				}
			]
		}
	]
}

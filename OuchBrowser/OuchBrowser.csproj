<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PublishSingleFile>true</PublishSingleFile>
		<SelfContained>true</SelfContained>
	</PropertyGroup>

	<ItemGroup>
		<SupportedPlatform Include="linux" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="GirCore.Adw-1" Version="0.7.0" />
		<PackageReference Include="GirCore.Gtk-4.0" Version="0.7.0" />
		<PackageReference Include="GirCore.WebKit-6.0" Version="0.7.0" />
	</ItemGroup>

	<ItemGroup>
		<!-- Icons -->
		<EmbeddedResource
			Include="OuchBrowser.app.gresource"
			LogicalName="OuchBrowser.app.gresource"
		/>
		<EmbeddedResource
			Include="Icons\chain-link-loose-symbolic.svg"
			LogicalName="chain-link-loose-symbolic.svg"
		/>
		<EmbeddedResource
			Include="Icons\shoe-box-symbolic.svg"
			LogicalName="shoe-box-symbolic.svg"
		/>
		<EmbeddedResource
			Include="Icons\site.srht.shrimple.ouch-symbolic.svg"
			LogicalName="site.srht.shrimple.ouch-symbolic.svg"
		/>
		<EmbeddedResource
			Include="Icons\sliders-horizontal-symbolic.svg"
			LogicalName="sliders-horizontal-symbolic.svg"
		/>

		<!-- GtkBuilder Files -->
		<EmbeddedResource Include="UI\Window.ui" LogicalName="UI\Window.ui" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\OuchBrowser.Plugins\OuchBrowser.Plugins.csproj" />
	</ItemGroup>

</Project>

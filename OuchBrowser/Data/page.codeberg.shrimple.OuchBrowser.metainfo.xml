<?xml version="1.0" encoding="UTF-8" ?>
<component type="desktop-application">
	<id>page.codeberg.shrimple.OuchBrowser</id>
	<icon type="stock">page.codeberg.shrimple.OuchBrowser</icon>
	<launchable type="desktop-id">page.codeberg.shrimple.OuchBrowser.desktop</launchable>
	<name>Ouch Browser</name>
	<developer id="site.srht.shrimple">
		<name>Shrimple Technologies</name>
		<url type="homepage">https://shrimple.srht.site/</url>
	</developer>
	<project_license>GPL-3.0-or-later</project_license>
	<metadata_license>CC0-1.0</metadata_license>
	<summary>Focus on your browsing</summary>
	<replaces>
		<id>site.srht.shrimple.ouch</id>
	</replaces>
	<translation type="gettext">OuchBrowser</translation>
	<branding>
		<color type="primary" scheme_preference="light">#cdab8f</color>
		<color type="primary" scheme_preference="dark">#b5835a</color>
	</branding>
	<content_rating type="oars-1.1" />
	<requires>
		<internet>always</internet>
		<display_length compare="ge">360</display_length>
	</requires>
	<supports>
		<control>pointing</control>
		<control>keyboard</control>
		<control>touch</control>
	</supports>
	<categories>
		<category>Network</category>
		<category>WebBrowser</category>
	</categories>
	<keywords>
		<keyword translate="no">browser</keyword>
		<keyword translate="no">internet</keyword>
		<keyword translate="no">www</keyword>
		<keyword translate="no">web</keyword>
		<keyword translate="no">explorer</keyword>
	</keywords>
	<update_contact>shrimple.tech_AT_proton.me</update_contact>
	<description>
		<p>
			Ouch Browser is a browser that utilizes the vertical tabs layout,
			which allows for better tab management for more heavy browser
			users. Made for focusing on your browsing, Ouch Browser comes with
			!bangs support, a multi-purpose command palette, and mobile
			support.
		</p>
		<p>
			NOTE: Ouch Browser is currently in alpha stage and is changing
			rapidly. While it is in a usable state, it does not have a large
			number of common web browser functions, and can have many bugs.
		</p>
	</description>
	<provides>
		<mediatype>text/html</mediatype>
	</provides>
	<url type="homepage">https://shrimple.codeberg.page/ouchbrowser.net/</url>
	<url type="bugtracker">https://codeberg.org/shrimple/OuchBrowser.NET/issues</url>
	<url type="vcs-browser">https://codeberg.org/shrimple/OuchBrowser.NET</url>
	<url type="translate">https://hosted.weblate.org/projects/ouch/net/</url>

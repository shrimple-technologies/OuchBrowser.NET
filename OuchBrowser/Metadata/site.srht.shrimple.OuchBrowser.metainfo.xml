<?xml version="1.0" encoding="UTF-8" ?>
<component type="desktop-application">
	<id>site.srht.shrimple.OuchBrowser</id>
	<icon type="stock">site.srht.shrimple.OuchBrowser</icon>
	<launchable
		type="desktop-id"
	>site.srht.shrimple.OuchBrowser.desktop</launchable>
	<name>Ouch Browser</name>
	<developer id="site.srht.shrimple">
		<name>Shrimple Technologies</name>
		<url type="homepage">https://shrimple.srht.site/</url>
	</developer>
	<project_license>GPL-3.0-or-later</project_license>
	<metadata_license>CC0-1.0</metadata_license>
	<summary>Focus on your browsing</summary>
	<replaces>
		<id>site.srht.shrimple.ouch</id>
	</replaces>
	<translation type="gettext">OuchBrowser</translation>
	<branding>
		<color type="primary" scheme_preference="light">#cdab8f</color>
		<color type="primary" scheme_preference="dark">#865e3c</color>
	</branding>
	<content_rating type="oars-1.1" />
	<requires>
		<internet>always</internet>
		<display_length compare="ge">360</display_length>
	</requires>
	<supports>
		<control>pointing</control>
		<control>keyboard</control>
		<control>touch</control>
	</supports>
	<categories>
		<category>Network</category>
		<category>WebBrowser</category>
	</categories>
	<keywords>
		<keyword>browser</keyword>
		<keyword>internet</keyword>
		<keyword>www</keyword>
		<keyword>web</keyword>
		<keyword>explorer</keyword>
	</keywords>
	<update_contact>max@woof.monster</update_contact>
	<description>
		<p
		>Ouch Browser isn’t just another web browser, it’s a whole new look on the web, with a modern look and feel, and a emphasis on productivity.</p>
		<p
		>NOTE: This is the C# rewrite, which is constantly evolving, and may be less stable than the original codebase.</p>
	</description>
	<provides>
		<mediatype>text/html</mediatype>
	</provides>
	<url type="homepage">https://shrimple.srht.site/blog/ouch/</url>
	<url
		type="bugtracker"
	>https://codeberg.org/shrimple/OuchBrowser.NET/issues</url>
	<url
		type="vcs-browser"
	>https://codeberg.org/shrimple/OuchBrowser.NET</url>
	<url
		type="translate"
	>https://hosted.weblate.org/projects/ouch/net/</url>
	<screenshots>
		<screenshot type="default">
			<image
			>https://codeberg.org/shrimple/OuchBrowser.NET/raw/branch/main/OuchBrowser/Screenshots/Screenshot%20with%20Sidebar%20Open.png</image>
		</screenshot>
		<screenshot>
			<image
			>https://codeberg.org/shrimple/OuchBrowser.NET/raw/branch/main/OuchBrowser/Screenshots/Screenshot%20with%20Sidebar%20Closed.png</image>
		</screenshot>
		<screenshot>
			<image
			>https://codeberg.org/shrimple/OuchBrowser.NET/raw/branch/main/OuchBrowser/Screenshots/Screenshot%20with%20Command%20Palette%20Open.png</image>
		</screenshot>
	</screenshots>
</component>

<?xml version="1.0" encoding="UTF-8" ?>
<schemalist>
	<schema
		id="site.srht.shrimple.OuchBrowser"
		path="/site/srht/shrimple/OuchBrowser/"
		gettext-domain="OuchBrowser"
	>
		<key type="s" name="search-engine">
			<choices>
				<choice value="https://bing.com/search?q=" />
				<choice value="https://duckduckgo.com/?q=" />
				<choice value="https://ecosia.org/search?q=" />
				<choice value="https://google.com/search?q=" />
				<choice value="https://kagi.com/search?q=" />
			</choices>
			<aliases>
				<alias value="Bing" target="https://bing.com/search?q=" />
				<alias value="DuckDuckGo" target="https://duckduckgo.com/?q=" />
				<alias value="Ecosia" target="https://ecosia.org/search?q=" />
				<alias value="Google" target="https://google.com/search?q=" />
				<alias value="Kagi" target="https://kagi.com/search?q=" />
			</aliases>

			<default>"https://duckduckgo.com/?q="</default>
			<summary>Search engine</summary>
			<description>
				This value is the search engine that will be used when the user
				enters a search query into the command palette.
			</description>
		</key>

		<key type="i" name="zoom">
			<choices>
				<choice value="25" />
				<choice value="33" />
				<choice value="50" />
				<choice value="67" />
				<choice value="75" />
				<choice value="80" />
				<choice value="90" />
				<choice value="100" />
				<choice value="110" />
				<choice value="125" />
				<choice value="150" />
				<choice value="175" />
				<choice value="175" />
				<choice value="200" />
				<choice value="250" />
				<choice value="300" />
				<choice value="400" />
				<choice value="500" />
			</choices>

			<default>100</default>
			<summary>Zoom</summary>
			<description>
				This value is the zoom level of the browser.
			</description>
		</key>
	</schema>
</schemalist>

#: OuchBrowser/CommandPalette.cs:54
#, csharp-format
msgid "Searching using {0}"
msgstr "Procurar usando {0}"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:29
#: OuchBrowser/Data/UI/Preferences.blp:160
#: OuchBrowser/Data/UI/Preferences.blp:170
msgid "Search Engine"
msgstr "Mecanismo de Pesquisa"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:30
msgid ""
"This value is the search engine that will be used when the user enters a "
"search query into the command palette."
msgstr ""
"Este valor define qual mecanismo de pesquisa será utilizado quando o "
"utilizador fizer uma consulta no painel de comandos."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:39
#: OuchBrowser/Data/UI/Shortcuts.blp:83
msgid "Zoom"
msgstr "Zoom"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:40
msgid ""
"This value is the zoom level of the browser. Please do not modify this value "
"yourself as this can create unintended side effects."
msgstr ""
"Este valor é o nível de zoom do navegador. Por favor, não modifique este "
"valor manualmente, pois isto pode gerar efeitos colaterais indesejados."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:49
msgid "Maximized?"
msgstr "Maximizado?"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:50
msgid "This value is whether the window is maximized or not."
msgstr "Este valor indica se a janela está maximizada ou não."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:61
#: OuchBrowser/Data/UI/RoomsOverview.blp:6
msgid "Rooms"
msgstr "Salas"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:62
msgid ""
"This value stores the rooms data. Each entry is a tuple: (room name, room "
"icon, pinned urls)."
msgstr ""
"Este valor armazena os dados das salas. Cada entrada é uma tupla: (nome da "
"sala, ícone da sala, urls fixadas)."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:71
msgid "Restored Tabs"
msgstr "Guias Restauradas"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:72
msgid "This value stores the tabs to restore."
msgstr "Este valor armazena as guias a serem restauradas."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:79
msgid "Search Autocomplete enabled?"
msgstr "Preenchimento automático da pesquisa ativado?"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:80
msgid "This value is whether search autocomplete is enabled or not."
msgstr ""
"Este valor indica se o preenchimento automático da pesquisa está ativado ou "
"não."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:87
msgid "!bang Autocomplete enabled?"
msgstr "Preenchimento automático do !bang ativado?"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:88
msgid "This value is whether !bang autocomplete is enabled or not."
msgstr ""
"Este valor indica se o preenchimento automático do !bang está ativado ou não."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:95
msgid "Developer Tools enabled?"
msgstr "Ferramentas de programador ativadas?"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:96
msgid "This value is whether developer tools is enabled or not."
msgstr ""
"Este valor indica se as ferramentas de programador estão ativadas ou não."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:103
msgid "Initial Window Size"
msgstr "Tamanho Inicial da Janela"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:104
msgid "This value is the main window’s size."
msgstr "Este valor define o tamanho da janela principal."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:111
msgid "Peek Tab Trigger"
msgstr "Atalho de Visualização Rápida"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:112
msgid ""
"This value is the trigger for opening a peek tab. For example, holding down "
"the Shift key and clicking on a hyperlink will result in that website being "
"loaded inside a peek tab, which is separate from the main window."
msgstr ""
"Este valor define o atalho para abrir uma guia de visualização rápida. Por "
"exemplo, segurar a tecla Shift e clicar numa liação fará com que o site seja "
"carregado numa guia de visualização rápida, separada da janela principal."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:123
msgid "!bang Usage Rankings"
msgstr ""

#: OuchBrowser/Data/OuchBrowser.gschema.xml:124
msgid "This value is the rankings of !bangs over time from use."
msgstr ""

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:6
#: OuchBrowser/Data/UI/Window.blp:15 OuchBrowser/Data/UI/Window.blp:268
#: OuchBrowser/Window.cs:91
msgid "Ouch Browser"
msgstr "Ouch Browser"

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:8
msgid "Shrimple Technologies"
msgstr "Shrimple Technologies"

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:13
msgid "Focus on your browsing"
msgstr "Foco na sua navegação"

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:46
msgid ""
"Ouch Browser is a browser that utilizes the vertical tabs layout, which "
"allows for better tab management for more heavy browser users. Made for "
"focusing on your browsing, Ouch Browser comes with !bangs support, a multi-"
"purpose command palette, and mobile support."
msgstr ""
"O Ouch Browser é um navegador que utiliza o layout de guias verticais, a "
"permitir uma melhor gestão de guias para utilizadores mais exigentes. Feito "
"para se concentrar na sua navegação, o Ouch Browser oferece apoio a !bangs, "
"um painel de comandos multifuncional e compatibilidade com dispositivos "
"móveis."

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:53
msgid ""
"NOTE: Ouch Browser is currently in alpha stage and is changing rapidly. "
"While it is in a usable state, it does not have a large number of common web "
"browser functions, and can have many bugs."
msgstr ""
"NOTA: O Ouch Browser está atualmente em fase alpha e a mudar rapidamente. "
"Embora já esteja num estado utilizável, ele ainda não possui muitos dos "
"recursos comuns de um navegador da web e pode apresentar vários bugs."

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:69
msgid "Ouch Browser’s Main Window"
msgstr "Janela Principal do Ouch Browser"

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:73
msgid "Ouch Browser with Tab Sidebar Closed"
msgstr "Ouch Browser com a Barra Lateral de Guias Fechada"

#: OuchBrowser/Data/page.codeberg.shrimple.OuchBrowser.metainfo.xml:77
msgid "Ouch Browser with Command Palette Opened"
msgstr "Ouch Browser com a Paleta de Comandos Aberta"


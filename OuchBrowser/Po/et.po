#: OuchBrowser/CommandPalette.cs:35
#, csharp-format
msgid "Searching using {0}"
msgstr "Otsing kasutades teenust {0}"

#: OuchBrowser/CommandPalette.cs:59
msgid "BANGS"
msgstr "BANG-käsud"

#: OuchBrowser/CommandPalette.cs:186
msgid "SUGGESTIONS"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:25
#: OuchBrowser/Data/UI/Preferences.blp:254
#: OuchBrowser/Data/UI/Preferences.blp:276
msgid "Search Engine"
msgstr "Mecanismo de Busca"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:26
msgid ""
"This value is the search engine that will be used when the user enters a "
"search query into the command palette."
msgstr ""

#: OuchBrowser/Data/OuchBrowser.gschema.xml:35
#: OuchBrowser/Data/UI/Shortcuts.blp:83
msgid "Zoom"
msgstr "Zoom"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:36
msgid ""
"This value is the zoom level of the browser. Please do not modify this value "
"yourself as this can create unintended side effects."
msgstr ""

#: OuchBrowser/Data/OuchBrowser.gschema.xml:45
msgid "Maximized?"
msgstr ""

#: OuchBrowser/Data/OuchBrowser.gschema.xml:46
msgid "This value is whether the window is maximized or not."
msgstr ""

#: OuchBrowser/Data/OuchBrowser.gschema.xml:57
msgid "Rooms"
msgstr "Salas"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:58
msgid ""
"This value stores the rooms data. Each entry is a tuple: (room name, room "
"icon, pinned urls)."
msgstr ""
"Este valor armazena os dados das salas. Cada entrada é uma tupla: (nome da "
"sala, ícone da sala, urls fixadas)."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:67
msgid "Restored Tabs"
msgstr "Abas Restauradas"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:68
msgid "This value stores the tabs to restore."
msgstr "Este valor armazena as abas a serem restauradas."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:75
msgid "Search Autocomplete enabled?"
msgstr "Preenchimento automático da pesquisa habilitado?"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:76
msgid "This value is whether search autocomplete is enabled or not."
msgstr ""
"Este valor indica se o preenchimento automático da pesquisa está habilitado "
"ou não."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:83
msgid "!bang Autocomplete enabled?"
msgstr "Preenchimento automático do !bang habilitado?"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:84
msgid "This value is whether !bang autocomplete is enabled or not."
msgstr ""
"Este valor indica se o preenchimento automático do !bang está habilitado ou "
"não."

#: OuchBrowser/Data/OuchBrowser.gschema.xml:91
msgid "Developer Tools enabled?"
msgstr "Ferramentas de desenvolvedor habilitadas?"

#: OuchBrowser/Data/OuchBrowser.gschema.xml:92
msgid "This value is whether developer tools is enabled or not."
msgstr ""
"Este valor indica se as ferramentas de desenvolvedor estão habilitadas ou "
"não."

#: OuchBrowser/Data/site.srht.shrimple.OuchBrowser.metainfo.xml:8
#: OuchBrowser/Data/UI/About.blp:6 OuchBrowser/Data/UI/Window.blp:20
#: OuchBrowser/Data/UI/Window.blp:248 OuchBrowser/UI.cs:77
msgid "Ouch Browser"
msgstr "Ouch Browser"

#: OuchBrowser/Data/site.srht.shrimple.OuchBrowser.metainfo.xml:10
#: OuchBrowser/Data/UI/About.blp:7
msgid "Shrimple Technologies"
msgstr "Shrimple Technologies"

#: OuchBrowser/Data/site.srht.shrimple.OuchBrowser.metainfo.xml:15
msgid "Focus on your browsing"
msgstr "Foque em sua navegação"

#: OuchBrowser/Data/site.srht.shrimple.OuchBrowser.metainfo.xml:47
msgid ""
"Ouch Browser is a browser that utilizes the vertical tabs layout, which "
"allows for better tab management for more heavy browser users. Made for "
"focusing on your browsing, Ouch Browser comes with !bangs support, a multi-"
"purpose command palette, and mobile support."
msgstr ""

#: OuchBrowser/Data/site.srht.shrimple.OuchBrowser.metainfo.xml:55
msgid ""
"NOTE: This is the C# rewrite, which is constantly evolving, and may be less "
"stable than the original codebase."
msgstr ""

